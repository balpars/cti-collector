# Copy to cti.env and fill in. Keep cti.env private (chmod 600); never commit it.

# --- Feed -------------------------------------------------------------------
# Free, no key (default if RANSOMWARE_LIVE_API is unset):
#export RANSOMWARE_LIVE_API="https://api.ransomware.live/v2/recentvictims"
# Pro (requires a key; note the X-API-KEY header is case-sensitive):
#export RANSOMWARE_LIVE_API="https://api-pro.ransomware.live/victims/recent"
#export RANSOMWARE_LIVE_API_KEY="your-ransomware-live-pro-key"

# --- Telegram sink ----------------------------------------------------------
export TELEGRAM_BOT_TOKEN="123456789:your-bot-token-from-botfather"
export TELEGRAM_CHAT_ID="your-numeric-chat-id"

# --- Webhook sink (optional; Discord/Slack/generic) -------------------------
#export WEBHOOK_URL="https://discord.com/api/webhooks/..."
#export WEBHOOK_TYPE="discord"   # discord | slack | generic

# --- State ------------------------------------------------------------------
export CTI_SEEN_FILE="/opt/cti/.cti_seen"
